#include <stdio.h>

// Recursive function
long long factorial_recursive(int n) {
    if (n == 0 || n == 1)
        return 1;
    return n * factorial_recursive(n - 1);
}

// Iterative function
long long factorial_iterative(int n) {
    long long fact = 1;
    for (int i = 1; i <= n; i++)
        fact *= i;
    return fact;
}

int main() {
    int choice, num;

    printf("Enter a number: ");
    scanf("%d", &num);

    if (num < 0) {
        printf("Invalid input! Factorial not defined for negative numbers.\n");
        return 0;
    }

    printf("\n1. Iterative Method\n");
    printf("2. Recursive Method\n");
    printf("Enter choice: ");
    scanf("%d", &choice);

    switch(choice) {
        case 1:
            printf("Factorial = %lld\n", factorial_iterative(num));
            break;

        case 2:
            printf("Factorial = %lld\n", factorial_recursive(num));
            break;

        default:
            printf("Invalid choice\n");
    }

    return 0;
}